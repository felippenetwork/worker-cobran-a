# Supabase — service role (bypassa RLS; nunca expor)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# Diretório de sessões Baileys no VPS (fora do diretório web)
SESSIONS_DIR=/opt/quita/sessions

# Log level: silent | error | warn | info | debug
LOG_LEVEL=warn
